{
  "method":"mlp",

  "model": {
    "name": "mlp",
    "hidden_sizes": [256, 128],
    "activation": "ReLU",
    "dropout": 0.0,
    "use_batchnorm": false,
    "mf": {
        "use_mf": true,
        "init_std": 0.01
    }
  },

  "training": {
    "lr": 0.001,
    "epochs": 20,
    "batch_size": 2048,
    "optimizer": "adam",
    "loss": "mse",
    "device": "auto"
  }
}
