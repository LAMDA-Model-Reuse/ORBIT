{
  "method":"HybridLLM",
  "router_mode":"deterministic",
  "router_tau":0.1,
  "router_threshold":0.5,

  "model": {
    "name": "mlp",
    "hidden_sizes": [256, 128],
    "activation": "ReLU",
    "dropout": 0.0,
    "use_batchnorm": false,
    "mf": {
        "use_mf": true,
        "init_std": 0.01
    }
  },

  "training": {
    "lr": 0.001,
    "epochs":50,
    "batch_size": 4096,
    "optimizer": "adam",
    "loss": "bce",
    "device": "auto"
  }
}
