{
   "_comment":"Please note that these parameters are fundamental parameters determined by the benchmark;changing them arbitrarily will result in errors!",
   "modality":"text+image",
   "voting":"weighted",
   "description_path":"./configs/description/mmrbench.json",
   "seed":42,
   "device": "cuda:3",
   "dataset": {
    "name": "MMRBench",
    "dataset_dir": "./data/mmrbench",
    "split": {
      "mode": "in-domain",
      "ratios": {
        "train": 0.2,
        "test": 0.8
      }
    }
  },
  "embeddings": {
    "text_model": "ViT-B/16",
    "image_model": "ViT-B/16",
    "batch_size": 128,
    "normalize": true,
    "training": false,
    "out_dim": 1024 
  }
}